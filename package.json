{
  "name": "open-remote-devcontainer",
  "displayName": "Open Remote - Devcontainer",
  "description": "Build & run a devcontainer using Docker or Podman CLI",
  "version": "0.3.3",
  "publisher": "mythreyak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mythreyak/open-remote-devcontainer.git"
  },
  "homepage": "https://github.com/mythreyak/open-remote-devcontainer#readme",
  "bugs": {
    "url": "https://github.com/mythreyak/open-remote-devcontainer/issues"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "devcontainer",
    "docker",
    "podman",
    "remote",
    "containers"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.devcontainer/devcontainer.json",
    "onResolveRemoteAuthority:devcontainer",
    "onCommand:openremotedevcontainer.addDockerfileTemplate",
    "onCommand:openremotedevcontainer.openFolderInDevcontainer",
    "onCommand:openremotedevcontainer.showMenu",
    "onCommand:openremotedevcontainer.openDevcontainerConfig",
    "onCommand:openremotedevcontainer.rebuildAndOpen",
    "onCommand:openremotedevcontainer.showLog",
    "onCommand:openremotedevcontainer.reopenLocally"
  ],
  "contributes": {
    "commands": [
      {
        "command": "openremotedevcontainer.addDockerfileTemplate",
        "title": "Devcontainer: Add Dockerfile Template"
      },
      {
        "command": "openremotedevcontainer.openFolderInDevcontainer",
        "title": "Devcontainer: Open Folder in container"
      },
      {
        "command": "openremotedevcontainer.showMenu",
        "title": "Devcontainer: Show Actions"
      },
      {
        "command": "openremotedevcontainer.openDevcontainerConfig",
        "title": "Devcontainer: Open Devcontainer Configuration"
      },
      {
        "command": "openremotedevcontainer.rebuildAndOpen",
        "title": "Devcontainer: Rebuild & repen in container"
      },
      {
        "command": "openremotedevcontainer.showLog",
        "title": "Devcontainer: Show Log"
      },
      {
        "command": "openremotedevcontainer.reopenLocally",
        "title": "Devcontainer: Reopen Folder Locally"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "openremotedevcontainer.showMenu"
        },
        {
          "command": "openremotedevcontainer.openDevcontainerConfig"
        },
        {
          "command": "openremotedevcontainer.openFolderInDevcontainer"
        },
        {
          "command": "openremotedevcontainer.rebuildAndOpen"
        },
        {
          "command": "openremotedevcontainer.showLog"
        },
        {
          "command": "openremotedevcontainer.reopenLocally",
          "when": "remoteName == devcontainer"
        }
      ],
      "explorer/context": [
        {
          "command": "openremotedevcontainer.openDevcontainerConfig",
          "group": "2_workspace",
          "when": "openremotedevcontainer.hasConfig"
        },
        {
          "command": "openremotedevcontainer.openFolderInDevcontainer",
          "group": "2_workspace",
          "when": "openremotedevcontainer.hasConfig"
        }
      ],
      "statusBar/remoteIndicator": [
        {
          "command": "openremotedevcontainer.openDevcontainerConfig",
          "group": "remote_30_devcontainer_3local@1",
          "when": "!remoteName && openremotedevcontainer.hasConfig"
        },
        {
          "command": "openremotedevcontainer.openFolderInDevcontainer",
          "group": "remote_30_devcontainer_3local@2",
          "when": "!remoteName && openremotedevcontainer.hasConfig"
        },
        {
          "command": "openremotedevcontainer.rebuildAndOpen",
          "group": "remote_30_devcontainer_3local@3",
          "when": "!remoteName && openremotedevcontainer.hasConfig"
        },
        {
          "command": "openremotedevcontainer.showLog",
          "group": "remote_30_devcontainer_3local@4"
        },
        {
          "command": "openremotedevcontainer.reopenLocally",
          "group": "remote_30_devcontainer_3remote@1",
          "when": "remoteName == devcontainer"
        }
      ]
    },
    "configuration": {
      "title": "Remote - devcontainer",
      "properties": {
        "remote.devcontainer.containerBinary": {
          "type": "string",
          "default": "docker",
          "description": "Container binary to use, e.g. 'docker' or 'podman'."
        },
        "remote.devcontainer.containerExtraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments passed to the container binary before the subcommand, e.g. ['--root', '/custom/storage']."
        }
      }
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "compile": "npm run check-types && npm run build",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "package": "npm run build:prod",
    "vsce:package": "vsce package",
    "dts": "cd src/typings && npx @vscode/dts main && npx @vscode/dts dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^20.19.41",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.12",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7"
  },
  "enabledApiProposals": [
    "resolvers",
    "contribViewsRemote"
  ]
}
